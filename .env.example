# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.
# Never commit real keys — .env.local is gitignored.
#
# EASIER: run `npm run setup` once, then manage every key from the browser at
# http://localhost:3000/admin → Key vault. You only need to edit this file by
# hand if you prefer to.

# --- Required ---

# Google Gemini API key — powers /api/analyze (website scan, script + 20 video ideas)
# and the Veo cinematic route (/api/generate-video). Get one at https://aistudio.google.com
# NOTE: Veo video generation needs BILLING ENABLED; the free tier quota is very small.
GEMINI_API_KEY=your_gemini_api_key_here

# HeyGen API key — powers avatar video generation (/api/heygen-video)
# and the 1000+ avatar catalog (/api/heygen-avatars). Get one at https://app.heygen.com
HEYGEN_API_KEY=your_heygen_api_key_here

# --- Optional (have sensible defaults) ---

# Max videos a single user (per IP) can generate per day. Default: 5
HEYGEN_DAILY_LIMIT=5

# Max spoken length of a generated video, in seconds. Default: 30
HEYGEN_MAX_SECONDS=30

# Daily per-user (per-IP) caps on the paid generation routes.
# Veo image-to-video (/api/generate-avatar). Default: 5
VIDEO_DAILY_LIMIT=5
# Gemini avatar images (/api/generate-avatar-image). Default: 20
IMAGE_DAILY_LIMIT=20
# Website scans (/api/analyze). Default: 25
ANALYZE_DAILY_LIMIT=25

# NOTE: these limits are held in memory, so they reset on restart / serverless
# cold start and are not shared across instances. Move them to Vercel KV or
# Redis before relying on them as a hard spend control in production.

# --- Admin access ---

# Admin dashboard password. Server-only (NOT NEXT_PUBLIC_) — it is never sent to
# the browser. Access is enforced in proxy.ts before any admin page renders.
# If this is unset, the admin area stays locked and shows a setup notice.
ADMIN_PASSWORD=change_me

# --- Optional: social profile links ---
# The footer renders an icon only for the handles you set here, so it never
# shows a dead link. Leave blank to hide that social icon entirely.
NEXT_PUBLIC_SOCIAL_TIKTOK=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# Optional. Secret used to sign admin session cookies. Set this to a long random
# string (e.g. `openssl rand -hex 32`) so that changing ADMIN_PASSWORD reliably
# invalidates existing sessions. Defaults to a value derived from ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Public domain. The product domain is www.myreelo.com and a production build
# already defaults to it, so you normally do NOT need to set this. Set it only
# to preview the site under a different address (staging URL, server IP) before
# DNS points at www.myreelo.com. Local development defaults to localhost.
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://www.myreelo.com
