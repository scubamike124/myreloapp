# =============================================================================
# Reelo — production environment manifest
# =============================================================================
# Every variable the application actually reads, grouped by whether it is
# required to launch. Copy the ones you need into your host's environment
# settings (not into a committed file). Values are examples, not real secrets.
#
# Audited against the code on 23 July 2026. The app integrates ONLY Gemini,
# HeyGen and a Postgres database. It does NOT use Supabase, Stripe, ElevenLabs,
# email, queues, webhooks, analytics or any social API — do not sign up for
# those to deploy.
# =============================================================================

# --- REQUIRED: the admin login (set once) ------------------------------------
# `npm run setup` generates these locally. In production, set them on the host.
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_SECRET=a-long-random-string

# --- REQUIRED to generate anything -------------------------------------------
GEMINI_API_KEY=your-gemini-key          # Amber, images, Veo video, storybooks, shorts
HEYGEN_API_KEY=your-heygen-key          # AI Avatar Studio, Website Commercial

# --- REQUIRED on any host without a persistent disk (Vercel, most PaaS) ------
# Accounts, tokens and the ledger. Any Postgres works (Neon free tier, etc.).
# On a host WITH a real disk (a VPS), leave this unset and SQLite is used.
DATABASE_URL=postgresql://user:pass@host/db

# --- Storage for finished videos ---------------------------------------------
# On a serverless host, set a Vercel Blob token. On a real disk, leave unset and
# files go under .data/media (or MEDIA_PATH). Cloudflare R2 is a cheaper option
# but needs the R2 storage driver added first — see INFRASTRUCTURE.md.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
# MEDIA_PATH=/var/lib/reelo/media
MEDIA_RETENTION_DAYS=30

# --- The public domain (already defaults to www.myreelo.com in production) ----
# Only set this to preview under a staging URL before DNS points at the domain.
# NEXT_PUBLIC_SITE_URL=https://staging.myreelo.com

# --- OPTIONAL: daily usage caps (protect against a runaway provider bill) -----
# All have sensible defaults; set only to change them. Lower while testing.
# VIDEO_DAILY_LIMIT=5
# HEYGEN_DAILY_LIMIT=5
# HEYGEN_MAX_SECONDS=30
# IMAGE_DAILY_LIMIT=20
# ANALYZE_DAILY_LIMIT=25
# STORYBOOK_DAILY_LIMIT=5
# STORY_MAKER_DAILY_LIMIT=5
# SHORTS_DAILY_LIMIT=10
# MEMORY_FILM_DAILY_LIMIT=10
# TRANSCRIBE_DAILY_LIMIT=30
# CAPTIONS_DAILY_LIMIT=30
# AUTH_ATTEMPTS_PER_DAY=20
# VIDEO_SECONDS=6

# --- OPTIONAL: footer social links (URLs only, not API keys) ------------------
# NEXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@yourhandle
# NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@yourhandle
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
# NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/yourpage

# --- NOT USED by the app (present only as vault placeholders) -----------------
# The admin key-vault lists STRIPE_SECRET_KEY, but no payment code reads it.
# Setting it does nothing until Stripe is actually built. Left here so nobody
# wastes time provisioning it expecting checkout to work.
# STRIPE_SECRET_KEY=
