# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# runtime-generated videos
/public/generated/
/public/assets/veo-test.mp4

# responsive audit output
.responsive-audit/
.responsive-audit.json
.interaction-audit.json

# one-off analysis scratch files
.check.mjs
.measure.mjs
.econ.mjs
.prop.mjs
.avg.mjs
